Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"paramsSat", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[Theta]", "->", "0.79999997"}], ",", 
      RowBox[{"\[Nu]0", "->", "0.100004"}], ",", 
      RowBox[{"\[Sigma]J0", "->", "0.323837"}], ",", 
      RowBox[{"s", "->", "5.99998"}], ",", 
      RowBox[{"mE", "->", "0.1999999"}], ",", 
      RowBox[{"K", "->", "250"}], ",", 
      RowBox[{"a", "->", "6"}]}], "}"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fitCareSat", "=", 
   RowBox[{"getFit", "[", 
    RowBox[{"paramsSat", ",", "\"\<Saturating\>\""}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"fitNoCareSat", "=", 
    RowBox[{"getFlippedFit", "[", 
     RowBox[{"paramsSat", ",", "\"\<Saturating\>\""}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"colCare", "=", 
   RowBox[{"RGBColor", "[", 

   ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"interpCareSat", "=", 
   RowBox[{"Interpolation", "[", "fitCareSat", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"interpNoCareSat", "=", 
    RowBox[{"Interpolation", "[", "fitNoCareSat", "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"cStarSat", "=", "0.2"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"cCrossSat", "=", "0.55"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"yStarSat", "=", 
   RowBox[{"Quiet", "@", 
    RowBox[{"Check", "[", 
     RowBox[{
      RowBox[{"interpCareSat", "[", "cStarSat", "]"}], ",", "Indeterminate"}],
      "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"yCrossSat", "=", 
    RowBox[{"Quiet", "@", 
     RowBox[{"Check", "[", 
      RowBox[{
       RowBox[{"interpNoCareSat", "[", "cCrossSat", "]"}], ",", 
       "Indeterminate"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", "\n"}], "\[IndentingNewLine]", 

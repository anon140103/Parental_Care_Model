Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"params", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[Theta]", "->", "0.8"}], ",", 
      RowBox[{"\[Nu]0", "->", "0.1"}], ",", 
      RowBox[{"\[Sigma]J0", "->", "0.323823"}], ",", 
      RowBox[{"s", "->", "6"}], ",", 
      RowBox[{"mE", "->", "0.2"}], ",", 
      RowBox[{"a", "->", "6"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"plotMuE", "=", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"tradeOff", "[", "\"\<Exp\>\"", "]"}], "[", 

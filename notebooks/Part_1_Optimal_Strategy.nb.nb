Cell[CellGroupData[{

Cell["Plots including linear", "Subtitle",
 CellChangeTimes->{{3.97660656512589*^9, 3.976606576855875*^9}, {
  3.976940608572033*^9, 3.976940609229312*^9}, {3.9844571146159077`*^9, 
  3.984457122274849*^9}},ExpressionUUID->"e2cf8361-aedb-45f3-a888-\
18cd01320bde"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"params2", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[Theta]", "->", "0.8"}], ",", 
      RowBox[{"\[Nu]0", "->", "0.1"}], ",", 
      RowBox[{"\[Sigma]J0", "->", "0.323"}], ",", 
      RowBox[{"s", "->", "6"}], ",", 
      RowBox[{"a", "->", "6"}], ",", 
      RowBox[{"mE", "->", "0.2"}], ",", 
      RowBox[{"K", "->", "250"}]}], "}"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"shapes2", "=", 
   RowBox[{"{", 
    RowBox[{"\"\<Exp\>\"", ",", "\"\<Saturating\>\"", ",", "\"\<Sigmoid\>\"", 
     ",", " ", "\"\<Linear\>\""}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"labels", "=", 
   RowBox[{"{", 
    RowBox[{"\"\<\[Mu](c)\>\"", ",", "\"\<r(c)\>\"", ",", "\"\<\[Nu](c)\>\"", 
     ",", "\"\<\[Sigma]J(c)\>\""}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"colors2", "=", 
    RowBox[{"{", 
     RowBox[{"Blue", ",", "Purple", ",", " ", "Red", ",", " ", "Green"}], 
     "}"}]}], ";"}], "  ", "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"traitVal2", "[", 
     RowBox[{"shape_", ",", "i_", ",", "c_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"tradeOff", "[", "shape", "]"}], "[", 
      RowBox[{"params2", ",", "c"}], "]"}], "[", 
     RowBox[{"[", "i", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"plots2", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Plot", "[", 
       RowBox[{
        RowBox[{"Evaluate", "@", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"traitVal2", "[", 
            RowBox[{"shape", ",", "i", ",", "c"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"shape", ",", "shapes2"}], "}"}]}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"c", ",", "0", ",", "2"}], "}"}], ",", 
        RowBox[{"PlotStyle", "->", 
         RowBox[{"Thread", "[", 
          RowBox[{"{", 
           RowBox[{"colors2", ",", "Thick"}], "}"}], "]"}]}], ",", 
        RowBox[{"PlotLegends", "->", "shapes2"}], ",", 
        RowBox[{"AxesLabel", "->", 
         RowBox[{"{", 
          RowBox[{"\"\<c\>\"", ",", 
           RowBox[{"labels", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], "}"}]}], ",", 
        RowBox[{"PlotRange", "->", "All"}], ",", 

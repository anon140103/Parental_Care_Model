  3.9844570261906223`*^9}},ExpressionUUID->"e9fb852c-29f7-4d59-b61d-\
6be66fcdd439"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"params", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Theta]", "->", "0.8"}], ",", 
       RowBox[{"\[Nu]0", "->", "0.1"}], ",", 
       RowBox[{"\[Sigma]J0", "->", "0.323823"}], ",", 
       RowBox[{"s", "->", "6"}], ",", 
       RowBox[{"mE", "->", "0.2"}], ",", 
       RowBox[{"a", "->", "6"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"shapes", "=", 
     RowBox[{"{", 
      RowBox[{"\"\<Saturating\>\"", ",", "\"\<Sigmoid\>\"", 
       ",", "\"\<Exp\>\""}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"colors", "=", 
     RowBox[{"{", 
      RowBox[{"Purple", ",", "Red", ",", " ", "Blue"}], "}"}]}], ";"}], "\n", 
   
   RowBox[{
    RowBox[{"labels", "=", 
     RowBox[{"{", 
      RowBox[{"\"\<\[Mu](c)\>\"", ",", "\"\<r(c)\>\"", ",", "\"\<\[Nu](c)\>\"",
        ",", "\"\<\[Sigma]J(c)\>\""}], "}"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"cmin", "=", "0"}], ";", 
    RowBox[{"cmax", "=", "2"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"trait", "[", 
      RowBox[{"shape_", ",", "i_", ",", "c_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{
       RowBox[{"tradeOff", "[", "shape", "]"}], "[", 
       RowBox[{"params", ",", "c"}], "]"}], "[", 
      RowBox[{"[", "i", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"plots", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Plot", "[", 
        RowBox[{
         RowBox[{"Evaluate", "@", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"trait", "[", 
             RowBox[{"shape", ",", "i", ",", "c"}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"shape", ",", "shapes"}], "}"}]}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"c", ",", "cmin", ",", "cmax"}], "}"}], ",", 
         RowBox[{"PlotStyle", "->", 
          RowBox[{"Thread", "[", 
           RowBox[{"{", 
            RowBox[{"colors", ",", "Thick"}], "}"}], "]"}]}], ",", 
         RowBox[{"PlotLegends", "->", "shapes"}], ",", 
         RowBox[{"PlotRange", "->", "All"}], ",", 
         RowBox[{"AxesLabel", "->", 
          RowBox[{"{", 
           RowBox[{"\"\<c\>\"", ",", 
            RowBox[{"labels", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}], "}"}]}], ",", 
         RowBox[{"PlotLabel", "->", 
          RowBox[{"labels", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], ",", 
         RowBox[{"ImageSize", "->", "450"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "4"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"GraphicsGrid", "[", 
    RowBox[{
     RowBox[{"Partition", "[", 
      RowBox[{"plots", ",", "2"}], "]"}], ",", 
     RowBox[{"Spacings", "->", 
      RowBox[{"{", 
       RowBox[{"0.5", ",", "0.8"}], "}"}]}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.976606338292025*^9, 3.976606342131113*^9}, 

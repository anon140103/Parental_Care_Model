 RowBox[{
  RowBox[{
   RowBox[{"colNoCare", "=", 
    RowBox[{"GrayLevel", "[", "0.3", "]"}]}], ";"}], "   ", "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"plotStyleSat", "=", 
